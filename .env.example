# Required
GEMINI_API_KEY=your_api_key_here
RSSHUB_BASE_URL=http://localhost:1200
OBSIDIAN_VAULT_PATH=/absolute/path/to/your/ObsidianVault
TARGET_ACCOUNTS=anthropicai,claudeai

# Optional
RSSHUB_ROUTE_TEMPLATE=/twitter/user/:account
TIMEZONE=Asia/Tokyo
OUTPUT_SUBDIR=AI Digest/Claude Code
RAW_SUBDIR=AI Digest/Claude Code/raw
ASSETS_SUBDIR=AI Digest/Claude Code/assets
STATE_DIR=.state
MAX_POSTS_PER_ACCOUNT=20
ONLY_INCLUDE_ORIGINAL_POSTS=true
SKIP_RETWEETS=true
SKIP_REPLIES=true
ENABLE_TRANSLATION=true
ENABLE_DIGEST=true
ENABLE_THUMBNAIL=true
MAX_HIGHLIGHTS=5
THUMBNAIL_COMMAND=bash scripts/generate-thumbnail.sh "{promptFile}" "{outputPath}"
THUMBNAIL_IMAGE_EXT=png
MODEL_TEXT=gemini-2.5-flash-lite
THUMBNAIL_PROMPT_STYLE=clean, modern, editorial, dark, subtle terminal motif, no text
REQUEST_TIMEOUT_MS=30000
