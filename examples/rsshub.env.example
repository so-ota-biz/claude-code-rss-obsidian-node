NODE_ENV=production
CACHE_TYPE=redis
REDIS_URL=redis://redis:6379/
CACHE_EXPIRE=600
ALLOW_ORIGIN=*

# Twitter/X Authentication - Choose one of the methods below:

# Method 1: Cookie Authentication (Recommended - no API application required)
# Get auth_token and ct0 from Twitter/X web browser cookies
# TWITTER_AUTH_TOKEN=your_auth_token_here
# TWITTER_COOKIE=auth_token=your_auth_token_here; ct0=your_ct0_here

# Method 2: Legacy Username/Password Authentication
# TWITTER_USERNAME=your_username
# TWITTER_PASSWORD=your_password

# Method 3: Twitter API Bearer Token (Requires Developer Portal application)
# TWITTER_BEARER_TOKEN=your_bearer_token_here
