{
  "name": "claude-code-rss-obsidian-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "run": "tsx src/index.ts",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "rsshub:up": "docker compose -f docker/docker-compose.rsshub.yml up -d",
    "rsshub:down": "docker compose -f docker/docker-compose.rsshub.yml down",
    "rsshub:logs": "docker compose -f docker/docker-compose.rsshub.yml logs -f"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "rss-parser": "^3.13.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/js-yaml": "^4.0.9",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
